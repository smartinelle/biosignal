# BioSignal Navigator — environment template.
# Copy to .env and fill values locally. NEVER commit .env (it is gitignored).
# The demo runs fully on deterministic fallbacks with NO keys set.

# --- LLM synthesis (Gemini) -------------------------------------------------
# The memo synthesizer supports two live routes plus a deterministic fallback.
#
# Route A — Gemini via OpenRouter (OpenAI-compatible). Recommended if you have
# an OpenRouter key (starts with "sk-or..."). Auto-detected from the key prefix.
#   GEMINI_API_KEY=sk-or-...                       # an OpenRouter key works here
#   GEMINI_MODEL=google/gemini-2.5-flash           # OpenRouter model id
# Or use an explicit OpenRouter variable instead of GEMINI_API_KEY:
#   OPENROUTER_API_KEY=sk-or-...
#   OPENROUTER_MODEL=google/gemini-2.5-flash
#
# Route B — native Google Gemini key (starts with "AIza...").
#   GEMINI_API_KEY=AIza...
#   GEMINI_MODEL=gemini-2.5-flash
#
# Optional: force an OpenAI-compatible base URL (e.g. another gateway).
#   GEMINI_BASE_URL=https://openrouter.ai/api/v1
GEMINI_API_KEY=
GEMINI_MODEL=
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=
# GEMINI_BASE_URL=

# --- Evidence retrieval (Tavily) --------------------------------------------
# When set, evidence cards are augmented with live literature/web sources.
TAVILY_API_KEY=

# --- Structured extraction (Pioneer / Fastino) ------------------------------
# The Pioneer side-challenge artifact is a deterministic GLiNER2-style extractor
# that runs WITHOUT credentials. To route extraction through a deployed Pioneer
# model, set BOTH the key and a deployed model id (both are required for live).
PIONEER_API_KEY=
PIONEER_MODEL_ID=
# PIONEER_BASE_URL=   # only if the Pioneer docs require a custom base URL

# --- Optional: fal generative media (not central to this build) -------------
FAL_KEY=
